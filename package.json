{
  "name": "bbuddy",
  "version": "0.1.0",
  "description": "Create your own coding companion — AI ASCII generation, parts assembly, custom stats. MCP server + hooks + statusline renderer for Claude Code and Codex CLI.",
  "main": "dist/server/index.js",
  "bin": {
    "bbuddy-statusline": "dist/statusline-wrapper.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".claude-plugin",
    ".codex-plugin",
    "hooks",
    "skills"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/creator/sprites', 'dist/creator/sprites', {recursive:true})\"",
    "start": "node dist/server/index.js",
    "dev": "ts-node src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "codex-cli",
    "companion",
    "ascii-art",
    "statusline",
    "virtual-pet",
    "coding-buddy"
  ],
  "author": {
    "name": "gokomong",
    "url": "https://github.com/gokomong"
  },
  "license": "MIT",
  "homepage": "https://github.com/gokomong/bbuddy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gokomong/bbuddy.git"
  },
  "bugs": {
    "url": "https://github.com/gokomong/bbuddy/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.4",
    "gif-encoder-2": "^1.0.5",
    "gifenc": "^1.0.3",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.40.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
