{
  "name": "bbuddy",
  "version": "0.1.0",
  "description": "Create your own coding companion — AI ASCII generation, parts assembly, custom stats",
  "main": "dist/server/index.js",
  "bin": {
    "bbuddy-statusline": "dist/statusline-wrapper.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/creator/sprites', 'dist/creator/sprites', {recursive:true})\"",
    "start": "node dist/server/index.js",
    "dev": "ts-node src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "gif-encoder-2": "^1.0.5",
    "gifenc": "^1.0.3",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.40.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
